<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ConectaYa | Panel de Control Profesional</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../../css/dashboard-trabajador.css">
    <link rel="stylesheet" href="../../css/inicio-trabajador.css">
</head>
<body class="dark-theme">

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo-neon">Conecta<span>Ya</span></div>
            </div>
            
            <nav class="sidebar-menu">
                <p class="menu-label">PANEL PROFESIONAL</p>
                <a href="inicio-trabajador.html" class="menu-item active">
                    <i class="fas fa-chart-pie"></i> <span>Resumen</span>
                </a>
                <a href="dashboard-perfil-trabajador.html" class="menu-item">
                    <i class="fas fa-briefcase"></i> <span>Mi Perfil</span>
                </a>
                <a href="mensajes-cliente.html" class="menu-item">
                    <i class="fas fa-comment-dots"></i> <span>Mensajes</span>
                </a>
                
                <p class="menu-label">ADMINISTRACIÓN</p>
                <a href="calendario-trabajador.html" class="menu-item">
                    <i class="fas fa-calendar-day"></i> <span>Agenda</span>
                </a>
                <a href="contratos-trabajador.html" class="menu-item">
                    <i class="fas fa-file-contract"></i> <span>Contratos</span>
                </a>
                <a href="notificaciones.html" class="menu-item">
                    <i class="fas fa-bell"></i> <span>Notificaciones</span>
                </a>
            </nav>

            <div class="sidebar-bottom">
                <button class="btn-role-toggle" onclick="window.location.href='inicio-cliente.html'">
                    <i class="fas fa-user"></i> Cambiar a Cliente
                </button>
                <a href="../../../backend/config/logout.php" class="logout-link">
                    <i class="fas fa-power-off"></i> Cerrar Sesión
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="content-header-premium">
                <div class="header-welcome">
                    <h1 class="welcome-text">Bienvenido, <span class="neon-text" id="worker-name">Profesional</span></h1>
                    <p class="header-desc">Aquí tienes el resumen de tu rendimiento y próximos servicios.</p>
                </div>
                <div class="header-date" id="current-date">
                    </div>
            </header>

            <section class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
                    <div class="stat-info">
                        <h3>Ganancias Mes</h3>
                        <p class="stat-value" id="monthly-earnings">$0.00</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-check-double"></i></div>
                    <div class="stat-info">
                        <h3>Completados</h3>
                        <p class="stat-value" id="completed-tasks">0</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-star"></i></div>
                    <div class="stat-info">
                        <h3>Calificación</h3>
                        <p class="stat-value" id="rating">0.0</p>
                    </div>
                </div>
            </section>

            <section class="main-section">
                <div class="premium-card">
                    <div class="card-header-premium">
                        <h3><i class="fas fa-clock"></i> Próximos Servicios Programados</h3>
                        <a href="calendario-trabajador.html" class="link-neon">Ver agenda completa</a>
                    </div>
                    <div class="manager-body">
                        <div id="pending-services-list" class="services-container">
                            <div class="loader-container">
                                <div class="spinner-neon"></div>
                                <p>Sincronizando con ConectaYa...</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="../../js/inicio-trabajador.js"></script>
</body>
</html>

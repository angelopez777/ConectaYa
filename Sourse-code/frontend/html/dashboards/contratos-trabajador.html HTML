<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ConectaYa | Mis Contratos Profesionales</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../../css/dashboard-trabajador.css">
    <link rel="stylesheet" href="../../css/contratos-trabajador.css">
</head>
<body class="dark-theme">

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo-neon">Conecta<span>Ya</span></div>
            </div>
            
            <nav class="sidebar-menu">
                <p class="menu-label">PRINCIPAL</p>
                <a href="inicio-trabajador.html" class="menu-item">
                    <i class="fas fa-chart-line"></i> <span>Mi Actividad</span>
                </a>
                <a href="dashboard-perfil-trabajador.html" class="menu-item">
                    <i class="fas fa-id-card"></i> <span>Perfil Profesional</span>
                </a>
                <a href="mensajes-cliente.html" class="menu-item">
                    <i class="fas fa-comments"></i> <span>Mensajes</span>
                </a>
                
                <p class="menu-label">GESTIÓN DE SERVICIOS</p>
                <a href="calendario-trabajador.html" class="menu-item">
                    <i class="fas fa-calendar-check"></i> <span>Mi Agenda</span>
                </a>
                <a href="contratos-trabajador.html" class="menu-item active">
                    <i class="fas fa-file-signature"></i> <span>Contratos Recibidos</span>
                </a>
                <a href="notificaciones.html" class="menu-item">
                    <i class="fas fa-bell"></i> <span>Notificaciones</span>
                </a>
            </nav>

            <div class="sidebar-bottom">
                <button class="btn-role-toggle" onclick="window.location.href='inicio-cliente.html'">
                    <i class="fas fa-user-tie"></i> Cambiar a Cliente
                </button>
                <a href="../../../backend/config/logout.php" class="logout-link">
                    <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="content-header-premium">
                <div class="header-info">
                    <h1 class="welcome-text">Panel de <span class="neon-text">Contratos Profesionales</span></h1>
                    <p class="header-desc">Gestiona tus acuerdos legales y estados de pago con tus clientes.</p>
                </div>
                <div class="header-stats-mini">
                    <div class="mini-stat">
                        <span class="label">Activos</span>
                        <span class="value neon-text" id="count-active">0</span>
                    </div>
                </div>
            </header>

            <section class="contracts-section">
                <div class="premium-card">
                    <div class="card-header-premium">
                        <h3><i class="fas fa-briefcase"></i> Historial de Acuerdos Laborales</h3>
                        <div class="header-actions">
                            <button class="btn-icon-neon" id="btn-refresh-contratos" title="Sincronizar con DB">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                    </div>

                    <div id="contracts-manager" class="manager-body">
                        <div id="table-view" class="table-scroll-premium" style="display: none;">
                            <table class="premium-table">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Servicio Pactado</th>
                                        <th>Fecha de Ejecución</th>
                                        <th>Presupuesto</th>
                                        <th>Estado Legal</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="lista-contratos-trabajador">
                                    </tbody>
                            </table>
                        </div>

                        <div id="status-view" class="empty-state-premium">
                            <div id="status-spinner" class="spinner-neon"></div>
                            <i id="status-icon" class="fas fa-file-contract empty-icon"></i>
                            <p id="status-text">Cargando acuerdos desde la base de datos...</p>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="../../js/contratos-trabajador.js"></script>
</body>
</html>
